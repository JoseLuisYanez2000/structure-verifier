{
  "name": "structure-verifier",
  "version": "1.1.2",
  "description": "TypeScript schema verification library with type inference, chainable rules, and detailed error reporting by path.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoseLuisYanez2000/structure-verifier.git"
  },
  "scripts": {
    "dev": "tsc-watch --onSuccess \"node ./dist/test/test.js\"",
    "clean": "rimraf dist/",
    "test": "npm run clean && npx tsc && npx jest",
    "test2": "tsc-watch --onSuccess \"node ./dist/index.test.js\"",
    "publicar": "npm run clean && npx tsc && npx jest && npm version patch && powershell -ExecutionPolicy Bypass -File ./scripts/publish.ps1"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/test/",
    "!dist/**/*.js.map"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "require": "./dist/fastify.js",
      "default": "./dist/fastify.js"
    }
  },
  "keywords": [],
  "author": "Jose Luis Yañez Macias",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.20",
    "fastify": "^5.8.5",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "tsc-watch": "^6.0.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dayjs": "^1.11.19"
  },
  "peerDependencies": {
    "fastify": ">=4"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  }
}
